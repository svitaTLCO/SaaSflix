{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2023"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@saasflix/config": [
        "packages/config/src/index.ts"
      ],
      "@saasflix/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@saasflix/domain-identity": [
        "packages/domain/identity/src/index.ts"
      ],
      "@saasflix/application": [
        "packages/application/src/index.ts"
      ],
      "@saasflix/telemetry": [
        "packages/telemetry/src/index.ts"
      ],
      "@saasflix/security": [
        "packages/security/src/index.ts"
      ],
      "@saasflix/domain-billing": [
        "packages/domain/billing/src/index.ts"
      ],
      "@saasflix/domain-entitlements": [
        "packages/domain/entitlements/src/index.ts"
      ],
      "@saasflix/domain-app-registry": [
        "packages/domain/app-registry/src/index.ts"
      ],
      "@saasflix/domain-releases": [
        "packages/domain/releases/src/index.ts"
      ],
      "@saasflix/domain-feed": [
        "packages/domain/feed/src/index.ts"
      ],
      "@saasflix/domain-discussions": [
        "packages/domain/discussions/src/index.ts"
      ],
      "@saasflix/domain-support": [
        "packages/domain/support/src/index.ts"
      ],
      "@saasflix/domain-notifications": [
        "packages/domain/notifications/src/index.ts"
      ],
      "@saasflix/domain-media": [
        "packages/domain/media/src/index.ts"
      ],
      "@saasflix/domain-search": [
        "packages/domain/search/src/index.ts"
      ],
      "@saasflix/domain-analytics": [
        "packages/domain/analytics/src/index.ts"
      ]
    }
  }
}
