{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": [
      "dom",
      "dom.iterable",
      "es2023"
    ],
    "jsx": "preserve",
    "types": [
      "node",
      "react",
      "react-dom"
    ]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "vitest.config.ts",
    "apps/**/*.config.ts",
    "eslint.config.mjs",
    "apps/**/next-env.d.ts"
  ]
}
