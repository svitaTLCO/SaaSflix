{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "es2023"],
    "composite": true,
    "plugins": [{ "name": "next" }],
    "incremental": true,
    "isolatedModules": true
  },
  "include": ["next-env.d.ts", "app/**/*.ts", "app/**/*.tsx", "src/**/*.ts"],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/config" },
    { "path": "../../packages/security" }
  ]
}
